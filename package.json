{
  "name": "azstechsnab-shop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate --schema prisma/schema.prisma && next build",
    "build:next": "next build",
    "build:prod": "prisma generate --schema prisma/schema.postgres.prisma && next build",
    "start": "next start",
    "lint": "eslint app components lib prisma tests playwright.config.ts tailwind.config.ts --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:generate:prod": "prisma generate --schema prisma/schema.postgres.prisma",
    "db:push": "prisma db push --schema prisma/schema.prisma",
    "db:push:prod": "prisma db push --schema prisma/schema.postgres.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "pretest:e2e": "prisma generate --schema prisma/schema.prisma && prisma db push --schema prisma/schema.prisma && tsx prisma/seed.ts",
    "test:e2e": "playwright test",
    "audit": "pnpm audit"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "bcryptjs": "3.0.2",
    "lucide-react": "0.468.0",
    "next": "15.5.18",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "1.56.1",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "22.10.2",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "autoprefixer": "10.5.1",
    "eslint": "8.57.0",
    "eslint-config-next": "15.5.18",
    "postcss": "8.5.15",
    "prisma": "6.19.3",
    "tailwindcss": "3.4.17",
    "tsx": "4.22.4",
    "typescript": "5.7.2"
  },
  "packageManager": "pnpm@11.7.0"
}
